{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

<style>
  /* ── HEALTHY AMERICA · Footer Styles ── */
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@600;700&family=Inter:wght@300;400;500&display=swap');

  :root {
    --ha-blue:       #0a3d7a;
    --ha-blue-soft:  #aac8f0;
    --ha-red:        #e33333;
    --ha-green-soft: #8dd6b2;
    --ha-dim:        rgba(255,255,255,0.10);
  }

  footer.footer {
    background-color: var(--ha-blue) !important;
    color: rgba(255,255,255,0.55) !important;
    font-family: 'Inter', sans-serif !important;
    border-top: none !important;
  }

  footer.footer .footer-block__heading,
  footer.footer h2.footer-block__heading {
    font-family: 'Syne', sans-serif !important;
    font-size: 10px !important;
    font-weight: 600 !important;
    letter-spacing: 0.13em !important;
    text-transform: uppercase !important;
    color: var(--ha-blue-soft) !important;
    margin-bottom: 16px !important;
  }

  footer.footer .footer-block__brand-info h2.footer-block__heading {
    font-size: 20px !important;
    letter-spacing: normal !important;
    text-transform: none !important;
    color: #ffffff !important;
    margin-bottom: 4px !important;
  }

  /* Specific headings to be bold and white */
  footer.footer .footer-block--menu .footer-block__heading.inline-richtext {
    color: #ffffff !important;
    font-weight: 700 !important;
  }

  footer.footer .footer-block__brand-info .rte,
  footer.footer .footer-block__brand-info .rte p,
  footer.footer .footer-block__details-content.rte,
  footer.footer .footer-block__details-content.rte p {
    font-size: 13px !important;
    font-weight: 300 !important;
    color: rgba(255,255,255,0.45) !important;
    line-height: 1.7 !important;
  }

  footer.footer .list-menu__item--link,
  footer.footer .link.link--text {
    color: rgba(255,255,255,0.50) !important;
    font-size: 13px !important;
    font-weight: 400 !important;
    text-decoration: none !important;
    transition: color 0.18s !important;
    line-height: 1.6 !important;
  }

  footer.footer .list-menu__item--link:hover,
  footer.footer .link.link--text:hover {
    color: #ffffff !important;
    text-decoration: none !important;
  }

  footer.footer .list-menu__item--active {
    color: var(--ha-blue-soft) !important;
    font-weight: 500 !important;
  }

  footer.footer .footer-block__newsletter h2.footer-block__heading,
  footer.footer .footer-block--newsletter h2.footer-block__heading {
    font-size: 10px !important;
    letter-spacing: 0.13em !important;
    text-transform: uppercase !important;
    color: var(--ha-blue-soft) !important;
  }

  footer.footer .footer__newsletter .field__input,
  footer.footer .newsletter-form .field__input {
    background-color: rgba(255,255,255,0.08) !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: 8px 0 0 8px !important;
    color: #ffffff !important;
    font-size: 13px !important;
    font-family: 'Inter', sans-serif !important;
    padding-right: 5rem !important;
  }

  footer.footer .footer__newsletter .field__input::placeholder,
  footer.footer .newsletter-form .field__input::placeholder {
    color: rgba(255,255,255,0.30) !important;
  }

  footer.footer .footer__newsletter .field__input:focus,
  footer.footer .newsletter-form .field__input:focus {
    border-color: rgba(170,200,240,0.50) !important;
    outline: none !important;
    box-shadow: none !important;
  }

  footer.footer .footer__newsletter .field__label,
  footer.footer .newsletter-form .field__label {
    color: rgba(255,255,255,0.30) !important;
  }

  footer.footer .newsletter-form__button.field__button {
    background-color: var(--ha-red) !important;
    border: none !important;
    border-radius: 0 8px 8px 0 !important;
    transition: background-color 0.18s !important;
  }

  footer.footer .newsletter-form__button.field__button:hover {
    background-color: #c41f1f !important;
  }

  footer.footer .newsletter-form__button svg,
  footer.footer .newsletter-form__button .svg-wrapper svg {
    color: #ffffff !important;
    fill: #ffffff !important;
    stroke: #ffffff !important;
  }

  footer.footer .newsletter-form__message--success {
    color: var(--ha-green-soft) !important;
  }

  footer.footer .newsletter-form__message:not(.newsletter-form__message--success) {
    color: #fca5a5 !important;
  }

  footer.footer .footer__list-social,
  footer.footer .list-social {
    gap: 8px !important;
    margin-top: 16px !important;
  }

  footer.footer .list-social__link {
    width: 36px !important;
    height: 36px !important;
    border-radius: 50% !important;
    background-color: rgba(255,255,255,0.08) !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    transition: background-color 0.18s, border-color 0.18s !important;
  }

  footer.footer .list-social__link:hover {
    background-color: rgba(255,255,255,0.16) !important;
    border-color: rgba(255,255,255,0.25) !important;
  }

  footer.footer .list-social__link svg,
  footer.footer .list-social__link .icon {
    fill: rgba(255,255,255,0.55) !important;
    width: 16px !important;
    height: 16px !important;
    transition: fill 0.18s !important;
  }

  footer.footer .list-social__link:hover svg,
  footer.footer .list-social__link:hover .icon {
    fill: #ffffff !important;
  }

  footer.footer .footer__content-bottom {
    border-top: 1px solid var(--ha-dim) !important;
    margin-top: 8px !important;
  }

  footer.footer .localization-form .localization-form__select,
  footer.footer .footer__localization select {
    background-color: rgba(255,255,255,0.08) !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: 8px !important;
    color: rgba(255,255,255,0.60) !important;
    font-size: 12px !important;
  }

  footer.footer .footer__localization .caption-large,
  footer.footer .footer__localization h2 {
    color: rgba(255,255,255,0.40) !important;
    font-size: 10px !important;
    letter-spacing: 0.10em !important;
    text-transform: uppercase !important;
  }

  footer.footer .list-payment__item .icon--full-color {
    opacity: 0.55 !important;
    border-radius: 4px !important;
    transition: opacity 0.18s !important;
  }

  footer.footer .list-payment__item:hover .icon--full-color {
    opacity: 0.85 !important;
  }

  footer.footer .footer__copyright,
  footer.footer .footer__copyright.caption {
    color: rgba(255,255,255,0.30) !important;
  }

  footer.footer .footer__copyright .copyright__content,
  footer.footer .footer__copyright small {
    color: rgba(255,255,255,0.30) !important;
    font-size: 11px !important;
  }

  footer.footer .footer__copyright a,
  footer.footer .copyright__content a {
    color: rgba(255,255,255,0.35) !important;
    text-decoration: none !important;
    transition: color 0.18s !important;
  }

  footer.footer .footer__copyright a:hover,
  footer.footer .copyright__content a:hover {
    color: rgba(255,255,255,0.65) !important;
  }

  footer.footer .footer__copyright .policies {
    display: flex !important;
    gap: 14px !important;
    flex-wrap: wrap !important;
  }

  footer.footer .footer__copyright .policies a {
    color: rgba(255,255,255,0.30) !important;
    font-size: 11px !important;
  }

  footer.footer .footer__copyright .policies a:hover {
    color: rgba(255,255,255,0.60) !important;
  }

  footer.footer .footer__follow-on-shop {
    margin-top: 16px !important;
  }

  /* Layout principal del footer top */
  footer.footer .footer__content-top {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 40px !important;
    align-items: start !important;
  }

  /* Columna izquierda: brand + newsletter + redes */
  footer.footer .footer-brand-col {
    display: flex !important;
    flex-direction: column !important;
    gap: 0 !important;
  }

  /* Columna derecha: las 3 columnas de links */
  footer.footer .footer-links-col {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
    gap: 32px !important;
  }

  footer.footer .footer-block--menu .list-unstyled {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 10px !important;
  }

  @media screen and (max-width: 768px) {
    footer.footer .footer__content-top {
      grid-template-columns: 1fr !important;
      gap: 24px !important;
    }
    
    footer.footer .footer-links-col {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 20px !important;
    }
    
    footer.footer .footer-block__brand-info {
      text-align: center !important;
      margin-bottom: 24px !important;
    }
    
    footer.footer .footer-block__newsletter {
      text-align: center !important;
    }
    
    footer.footer .footer__newsletter .field__input {
      width: 100% !important;
      max-width: 300px !important;
      margin: 0 auto 12px !important;
    }
    
    footer.footer .newsletter-form__button.field__button {
      width: 100% !important;
      max-width: 300px !important;
      margin: 0 auto !important;
    }
    
    footer.footer .list-social__item {
      justify-content: center !important;
      margin-top: 16px !important;
    }
  }

  @media screen and (max-width: 480px) {
    footer.footer .footer-links-col {
      grid-template-columns: 1fr !important;
      gap: 16px !important;
    }
    
    footer.footer .footer-block__heading,
    footer.footer h2.footer-block__heading {
      font-size: 11px !important;
      margin-bottom: 12px !important;
    }
    
    footer.footer .list-menu__item--link,
    footer.footer .link.link--text {
      font-size: 12px !important;
      line-height: 1.5 !important;
    }
    
    footer.footer .list-social__link {
      width: 32px !important;
      height: 32px !important;
    }
    
    footer.footer .list-social__link svg,
    footer.footer .list-social__link .icon {
      width: 14px !important;
      height: 14px !important;
    }
  }

  @media screen and (max-width: 768px) {
    footer.footer .footer-block__newsletter {
      text-align: center !important;
      margin: 20px 0 !important;
    }
    
    footer.footer .footer-block__newsletter h2.footer-block__heading,
    footer.footer .footer-block--newsletter h2.footer-block__heading {
      text-align: center !important;
      margin-bottom: 16px !important;
    }
    
    footer.footer .footer__newsletter .field__input,
    footer.footer .newsletter-form .field__input {
      width: 100% !important;
      max-width: 300px !important;
      margin: 0 auto 12px !important;
      padding: 12px 16px !important;
      font-size: 14px !important;
    }
    
    footer.footer .footer__newsletter .field__input::placeholder,
    footer.footer .newsletter-form .field__input::placeholder {
      font-size: 14px !important;
    }
    
    footer.footer .footer__newsletter .field__label,
    footer.footer .newsletter-form .field__label {
      font-size: 12px !important;
      margin-bottom: 8px !important;
    }
    
    footer.footer .newsletter-form .field {
      flex-direction: column !important;
      align-items: center !important;
    }

    footer.footer .newsletter-form__button.field__button {
      position: relative !important;
      right: auto !important;
      top: auto !important;
      width: 100% !important;
      max-width: 300px !important;
      margin: 0 auto !important;
      padding: 14px 20px !important;
      font-size: 14px !important;
      font-weight: 600 !important;
      border-radius: 8px !important;
    }
    
    footer.footer .footer__localization {
      text-align: center !important;
      margin-top: 20px !important;
    }
    
    footer.footer .localization-form .localization-form__select,
    footer.footer .footer__localization select {
      width: 100% !important;
      max-width: 200px !important;
      margin: 0 auto !important;
      padding: 10px !important;
      font-size: 13px !important;
    }
    
    footer.footer .footer__localization .caption-large,
    footer.footer .footer__localization h2 {
      font-size: 11px !important;
      margin-bottom: 8px !important;
    }
  }
</style>

{%- style -%}
  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer {
      margin-top: {{ section.settings.margin_top }}px;
    }

    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">

  <div class="footer__content-top page-width">

    <!-- ── COLUMNA IZQUIERDA: Brand + Newsletter + Redes ── -->
    <div class="footer-brand-col">

      <!-- Brand info -->
      <div class="footer-block__brand-info">
        {%- if settings.brand_image != blank -%}
          {%- assign brand_image_height = settings.brand_image_width | divided_by: settings.brand_image.aspect_ratio -%}
          <div class="footer-block__image-wrapper" style="max-width: min(100%, {{ settings.brand_image_width }}px);">
            {{
              settings.brand_image
              | image_url: width: 1100
              | image_tag:
                loading: 'lazy',
                widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                height: brand_image_height,
                width: settings.brand_image_width
            }}
          </div>
        {%- endif -%}

        {%- if settings.brand_headline != blank -%}
          <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
        {%- else -%}
          <h2 class="footer-block__heading rte">{{ shop.name }}</h2>
        {%- endif -%}

        {%- if settings.brand_description != blank -%}
          <div class="rte">{{ settings.brand_description }}</div>
        {%- else -%}
          <div class="rte"><p>Productos de nutrición y bienestar de calidad premium, disponibles en Cali y con envío a toda Colombia.</p></div>
        {%- endif -%}
      </div>

      <!-- Newsletter -->
      {%- if section.settings.newsletter_enable -%}
        <div class="footer-block__newsletter">
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
          {%- else -%}
            <h2 class="footer-block__heading inline-richtext">Suscribe para recibir ofertas</h2>
          {%- endif -%}
          {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="ContactFooter-error"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="ContactFooter-success"
                  {% endif %}
                  placeholder="{{ 'newsletter.label' | t }}"
                  required
                >
                <label class="field__label" for="NewsletterForm--{{ section.id }}">
                  {{ 'newsletter.label' | t }}
                </label>
                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  id="Subscribe"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  <span class="svg-wrapper">
                    {{- 'icon-arrow.svg' | inline_asset_content -}}
                  </span>
                </button>
              </div>
              {%- if form.errors -%}
                <small class="newsletter-form__message form__message" id="ContactFooter-error">
                  <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
            </div>
            {%- if form.posted_successfully? -%}
              <h3
                class="newsletter-form__message newsletter-form__message--success form__message"
                id="ContactFooter-success"
                tabindex="-1"
                autofocus
              >
                <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

      <!-- Follow on Shop -->
      {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
        <div class="footer__follow-on-shop">
          {{ shop | login_button: action: 'follow' }}
        </div>
      {%- endif -%}

      <!-- Redes sociales -->
      {%- liquid
        assign has_social_icons = true
        if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
          assign has_social_icons = false
        endif
      -%}
      {%- if section.settings.show_social and has_social_icons -%}
        {%- render 'social-icons', class: 'footer__list-social' -%}
      {%- endif -%}

    </div>
    <!-- FIN columna izquierda -->

    <!-- ── COLUMNA DERECHA: Empresa · Soporte · Nuestras líneas ── -->
    <div class="footer-links-col">

      <!-- EMPRESA -->
      <div class="footer-block footer-block--menu">
        <h2 class="footer-block__heading inline-richtext">Empresa</h2>
        <ul class="footer-block__details-content list-unstyled">
          <li><a href="/pages/sobre-nosotros" class="link link--text list-menu__item list-menu__item--link">Sobre nosotros</a></li>
          <li><a href="/pages/nuestra-mision" class="link link--text list-menu__item list-menu__item--link">Nuestra misión</a></li>
          <li><a href="/blogs/salud" class="link link--text list-menu__item list-menu__item--link">Blog de salud</a></li>
          <li><a href="/pages/contacto" class="link link--text list-menu__item list-menu__item--link">Contacto</a></li>
        </ul>
      </div>

      <!-- SOPORTE -->
      <div class="footer-block footer-block--menu">
        <h2 class="footer-block__heading inline-richtext">Soporte</h2>
        <ul class="footer-block__details-content list-unstyled">
          <li><a href="/pages/preguntas-frecuentes" class="link link--text list-menu__item list-menu__item--link">Preguntas frecuentes</a></li>
          <li><a href="/pages/politica-de-envios" class="link link--text list-menu__item list-menu__item--link">Política de envíos</a></li>
          <li><a href="/pages/devoluciones" class="link link--text list-menu__item list-menu__item--link">Devoluciones</a></li>
          <li><a href="/pages/rastrear-pedido" class="link link--text list-menu__item list-menu__item--link">Rastrear pedido</a></li>
        </ul>
      </div>

      <!-- NUESTRAS LÍNEAS -->
      <div class="footer-block footer-block--menu">
        <h2 class="footer-block__heading inline-richtext">Nuestras líneas</h2>
        <ul class="footer-block__details-content list-unstyled">
          <li><a href="/collections/healthy-america" class="link link--text list-menu__item list-menu__item--link">Healthy America</a></li>
          <li><a href="/collections/healthy-sports" class="link link--text list-menu__item list-menu__item--link">Healthy Sports</a></li>
          <li><a href="/collections/nutrivita" class="link link--text list-menu__item list-menu__item--link">Nutrivita</a></li>
        </ul>
      </div>

    </div>
    <!-- FIN columna derecha -->

  </div>
  <!-- FIN footer__content-top -->

  <!-- ── BOTTOM: país · pagos · copyright ── -->
  <div class="footer__content-bottom">
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer__column footer__localization isolate">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
                {%- render 'country-localization', localPosition: 'FooterCountry' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}

        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div>
                <h2 class="caption-large text-body" id="FooterLanguageLabel">{{ 'localization.language_label' | t }}</h2>
                {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      <div class="footer__column footer__column--info">
        {%- if section.settings.payment_enable -%}
          <div class="footer__payment">
            <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
            <ul class="list list-payment" role="list">
              {%- for type in shop.enabled_payment_types -%}
                <li class="list-payment__item">
                  {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="footer__content-bottom-wrapper page-width{% if section.settings.enable_country_selector == false and section.settings.enable_language_selector == false %} footer__content-bottom-wrapper--center{% endif %}">
      <div class="footer__copyright caption">
        <small class="copyright__content">&copy; {{ 'now' | date: '%Y' }}, {{ shop.name | link_to: routes.root_url }}</small>
        <small class="copyright__content">{{ powered_by_link }}</small>
        {%- if section.settings.show_policy -%}
          <ul class="policies list-unstyled">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li>
                  <small class="copyright__content"><a href="{{ policy.url }}">{{ policy.title | escape }}</a></small>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
