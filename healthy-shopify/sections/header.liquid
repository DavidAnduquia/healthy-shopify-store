<script>
(function () {
  'use strict';

  /* ================================================================
     MARQUEE CONTINUO SIN SALTO
     ─────────────────────────────────────────────────────────────────
     La raíz del problema con CSS keyframes + translateX(-50%):
       El porcentaje -50% asume que los dos "mitades" del track son
       EXACTAMENTE iguales en píxeles. Sub-pixel rendering, zoom del
       navegador o diferencias de fuente rompen esa igualdad y
       producen el micro-salto visible al hacer el reset.

     Solución aquí:
       • Solo hay UN span "fuente" en el HTML.
       • Después de cargar la fuente, medimos su offsetWidth real → itemW.
       • Clonamos ese span hasta tener suficientes copias para cubrir
         la pantalla × 2 (nunca quedará un hueco).
       • Cada frame: offset += speed.
       • Cuando offset >= itemW → offset -= itemW   ← RESET EXACTO.
         Este valor es el mismo que medimos, no un porcentaje.
         El primer clon reemplaza visualmente al original sin diferencia
         de posición → cero salto.
  ================================================================ */
  function initMarquee() {
    var track  = document.getElementById('ha-ann-track');
    var source = document.getElementById('ha-ann-source');
    if (!track || !source) return;

    var speed  = 0.65;   // px / frame  (~39 px/s a 60 fps)
    var offset = 0;
    var itemW  = 0;
    var raf    = null;
    var paused = false;

    function build() {
      itemW = source.offsetWidth;

      // Si la fuente no cargó aún, offsetWidth puede ser 0 → reintentar
      if (itemW === 0) {
        requestAnimationFrame(build);
        return;
      }

      var containerW = track.parentElement.offsetWidth || window.innerWidth;

      // Cuántos clones necesitamos para cubrir containerW × 2 + margen
      var needed = Math.ceil((containerW * 2) / itemW) + 3;

      // Eliminar clones anteriores (por si se recalcula en resize)
      Array.prototype.forEach.call(
        track.querySelectorAll('[aria-hidden="true"]'),
        function (el) { track.removeChild(el); }
      );

      for (var i = 0; i < needed; i++) {
        var clone = source.cloneNode(true);
        clone.removeAttribute('id');
        clone.setAttribute('aria-hidden', 'true');
        track.appendChild(clone);
      }

      offset = 0;
      if (raf) cancelAnimationFrame(raf);
      raf = requestAnimationFrame(tick);
    }

    function tick() {
      if (!paused) {
        offset += speed;

        // Reset EXACTO: cuando avanzamos un itemW completo,
        // retrocedemos ese mismo valor. El siguiente clon ya
        // está justo donde estaba el anterior → sin salto.
        if (offset >= itemW) {
          offset -= itemW;
        }

        track.style.transform = 'translateX(' + (-offset) + 'px)';
      }
      raf = requestAnimationFrame(tick);
    }

    // Pausar al hover (accesibilidad / comodidad de lectura)
    var bar = document.getElementById('ha-announcement');
    if (bar) {
      bar.addEventListener('mouseenter', function () { paused = true;  });
      bar.addEventListener('mouseleave', function () { paused = false; });
    }

    // Recalcular si el viewport cambia de tamaño
    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(build, 250);
    }, { passive: true });

    // Esperar a que la fuente esté lista antes de medir
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(build);
    } else {
      setTimeout(build, 350); // fallback Safari antiguo
    }
  }

  /* ================================================================
     STICKY SCROLL
  ================================================================ */
  var headerEl = document.getElementById('ha-header');
  var ticking  = false;
  window.addEventListener('scroll', function () {
    if (!ticking) {
      requestAnimationFrame(function () {
        if (headerEl) headerEl.classList.toggle('scrolled', window.scrollY > 40);
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  /* ================================================================
     MOBILE DRAWER
  ================================================================ */
  var menuToggle  = document.getElementById('ha-menu-toggle');
  var drawer      = document.getElementById('ha-mobile-drawer');
  var drawerClose = document.getElementById('ha-drawer-close');
  var backdrop    = document.getElementById('ha-drawer-backdrop');
  var body        = document.body;

  function openDrawer()  {
    drawer.classList.add('open');
    menuToggle.setAttribute('aria-expanded', 'true');
    body.style.overflow = 'hidden';
    if (drawerClose) drawerClose.focus();
  }
  function closeDrawer() {
    drawer.classList.remove('open');
    menuToggle.setAttribute('aria-expanded', 'false');
    body.style.overflow = '';
    if (menuToggle) menuToggle.focus();
  }
  if (menuToggle)  menuToggle.addEventListener('click', function() {
    drawer.classList.contains('open') ? closeDrawer() : openDrawer();
  });
  if (drawerClose) drawerClose.addEventListener('click', closeDrawer);
  if (backdrop)    backdrop.addEventListener('click', closeDrawer);

  /* ================================================================
     SEARCH OVERLAY
  ================================================================ */
  var searchToggle  = document.getElementById('ha-search-toggle');
  var searchOverlay = document.getElementById('ha-search-overlay');
  var searchClose   = document.getElementById('ha-search-close');
  var searchInput   = document.getElementById('ha-search-input');

  function openSearch() {
    searchOverlay.classList.add('open');
    if (searchToggle) searchToggle.setAttribute('aria-expanded', 'true');
    body.style.overflow = 'hidden';
    setTimeout(function () { if (searchInput) searchInput.focus(); }, 80);
  }
  function closeSearch() {
    searchOverlay.classList.remove('open');
    if (searchToggle) searchToggle.setAttribute('aria-expanded', 'false');
    body.style.overflow = '';
    if (searchToggle) searchToggle.focus();
  }
  if (searchToggle)  searchToggle.addEventListener('click', openSearch);
  if (searchClose)   searchClose.addEventListener('click', closeSearch);
  if (searchOverlay) searchOverlay.addEventListener('click', function (e) {
    if (e.target === searchOverlay) closeSearch();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key !== 'Escape') return;
    if (drawer      && drawer.classList.contains('open'))        closeDrawer();
    if (searchOverlay && searchOverlay.classList.contains('open')) closeSearch();
  });

  /* ================================================================
     CART COUNT BOUNCE-IN
  ================================================================ */
  var cartCount = document.querySelector('.ha-cart-count');
  if (cartCount) setTimeout(function () { cartCount.classList.add('visible'); }, 600);

  /* ================================================================
     DAWN COMPAT: sticky-header custom element
  ================================================================ */
  if (!customElements.get('sticky-header')) {
    customElements.define('sticky-header', class extends HTMLElement {
      connectedCallback() {
        this.header = document.querySelector('.section-header');
        this.headerIsAlwaysSticky =
          this.getAttribute('data-sticky-type') === 'always' ||
          this.getAttribute('data-sticky-type') === 'reduce-logo-size';
        this.headerBounds = {};
        this.setHeaderHeight();
        window.matchMedia('(max-width: 990px)').addEventListener('change', this.setHeaderHeight.bind(this));
        if (this.headerIsAlwaysSticky && this.header)
          this.header.classList.add('shopify-section-header-sticky');
        this.currentScrollTop = 0;
        this.preventReveal = false;
        this.predictiveSearch = this.querySelector('predictive-search');
        this.onScrollHandler = this.onScroll.bind(this);
        this.hideHeaderOnScrollUp = () => this.preventReveal = true;
        this.addEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
        window.addEventListener('scroll', this.onScrollHandler, false);
        this.createObserver();
      }
      setHeaderHeight() {
        if (this.header)
          document.documentElement.style.setProperty('--header-height', `${this.header.offsetHeight}px`);
      }
      disconnectedCallback() {
        this.removeEventListener('preventHeaderReveal', this.hideHeaderOnScrollUp);
        window.removeEventListener('scroll', this.onScrollHandler);
      }
      createObserver() {
        const o = new IntersectionObserver((entries, obs) => {
          this.headerBounds = entries[0].intersectionRect; obs.disconnect();
        });
        if (this.header) o.observe(this.header);
      }
      onScroll() {
        const st = window.pageYOffset || document.documentElement.scrollTop;
        if (this.predictiveSearch && this.predictiveSearch.isOpen) return;
        const bot = this.headerBounds.bottom || 0;
        const top = this.headerBounds.top    || 0;
        if (st > this.currentScrollTop && st > bot) {
          this.header && this.header.classList.add('scrolled-past-header');
          if (!this.preventHide) requestAnimationFrame(this.hide.bind(this));
        } else if (st < this.currentScrollTop && st > bot) {
          this.header && this.header.classList.add('scrolled-past-header');
          if (!this.preventReveal) {
            requestAnimationFrame(this.reveal.bind(this));
          } else {
            clearTimeout(this.isScrolling);
            this.isScrolling = setTimeout(() => { this.preventReveal = false; }, 66);
            requestAnimationFrame(this.hide.bind(this));
          }
        } else if (st <= top) {
          this.header && this.header.classList.remove('scrolled-past-header');
          requestAnimationFrame(this.reset.bind(this));
        }
        this.currentScrollTop = st;
      }
      hide()   { if (!this.headerIsAlwaysSticky && this.header) this.header.classList.add('shopify-section-header-hidden','shopify-section-header-sticky'); }
      reveal() { if (!this.headerIsAlwaysSticky && this.header) { this.header.classList.add('shopify-section-header-sticky','animate'); this.header.classList.remove('shopify-section-header-hidden'); } }
      reset()  { if (!this.headerIsAlwaysSticky && this.header) this.header.classList.remove('shopify-section-header-hidden','shopify-section-header-sticky','animate'); }
    });
  }

  /* Arrancar marquee */
  initMarquee();

})();
</script>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}"logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},{% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},{{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},{{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},{{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},{{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

