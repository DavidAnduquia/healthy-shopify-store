{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- if section.settings.quick_add != 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .complete-stack__title {
    margin: 0 0 0.5rem;
  }

  .complete-stack__empty {
    text-align: center;
    padding: 2rem;
    color: rgba(var(--color-foreground), 0.55);
  }
{%- endstyle -%}

{%- comment %}
  Detect current product brand from tags.
{% endcomment -%}
{%- assign current_product_line = '' -%}
{%- assign product_title_lower = product.title | downcase -%}

{%- if product_title_lower contains 'healthy sports' -%}
  {%- assign current_product_line = 'Healthy Sports' -%}
{%- elsif product_title_lower contains 'healthy america' -%}
  {%- assign current_product_line = 'Healthy America' -%}
{%- elsif product_title_lower contains 'nutrivita' -%}
  {%- assign current_product_line = 'Nutrivita' -%}
{%- endif -%}

{%- if current_product_line == '' -%}
  {%- for tag in product.tags -%}
    {%- assign tag_lower = tag | downcase -%}
    {%- if tag_lower contains 'healthy-sports' or tag_lower contains 'healthy sports' -%}
      {%- assign current_product_line = 'Healthy Sports' -%}
      {%- break -%}
    {%- elsif tag_lower contains 'healthy-america' or tag_lower contains 'healthy america' -%}
      {%- assign current_product_line = 'Healthy America' -%}
      {%- break -%}
    {%- elsif tag_lower contains 'nutrivita' -%}
      {%- assign current_product_line = 'Nutrivita' -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if current_product_line == '' and product.collections.size > 0 -%}
  {%- for collection in product.collections -%}
    {%- assign collection_title_lower = collection.title | downcase -%}
    {%- if collection_title_lower contains 'healthy sports' -%}
      {%- assign current_product_line = 'Healthy Sports' -%}
      {%- break -%}
    {%- elsif collection_title_lower contains 'healthy america' -%}
      {%- assign current_product_line = 'Healthy America' -%}
      {%- break -%}
    {%- elsif collection_title_lower contains 'nutrivita' -%}
      {%- assign current_product_line = 'Nutrivita' -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if current_product_line != '' -%}
  {%- liquid
    assign products_to_show = section.settings.products_to_show
    assign current_handle = product.handle
    assign columns_mobile_int = section.settings.columns_mobile | plus: 0
    assign columns_desktop_int = section.settings.columns_desktop | plus: 0

    if current_product_line == 'Healthy Sports'
      assign other_brands = 'healthy-america,nutrivita' | split: ','
    elsif current_product_line == 'Healthy America'
      assign other_brands = 'healthy-sports,nutrivita' | split: ','
    elsif current_product_line == 'Nutrivita'
      assign other_brands = 'healthy-sports,healthy-america' | split: ','
    else
      assign other_brands = '' | split: ','
    endif

    assign block_match_count = 0
    for block in section.blocks
      assign bp = all_products[block.settings.product]
      assign bl = block.settings.product_line
      if bp != blank and bl != current_product_line and bp.handle != current_handle
        assign block_match_count = block_match_count | plus: 1
      endif
    endfor

    assign from_blocks = block_match_count
    if from_blocks > products_to_show
      assign from_blocks = products_to_show
    endif

    assign slots_left = products_to_show | minus: from_blocks
    if slots_left < 0
      assign slots_left = 0
    endif

    assign collection_fill = 0
    for coll_handle in other_brands
      assign col = collections[coll_handle]
      for coll_product in col.products limit: 50
        if collection_fill >= slots_left
          break
        endif
        unless coll_product.handle == current_handle
          assign dup = false
          for block in section.blocks
            assign bp = all_products[block.settings.product]
            if bp != blank and bp.handle == coll_product.handle
              assign dup = true
              break
            endif
          endfor
          unless dup
            assign collection_fill = collection_fill | plus: 1
          endunless
        endunless
      endfor
    endfor

    assign total_products = from_blocks | plus: collection_fill
    assign show_mobile_slider = false
    if section.settings.swipe_on_mobile and total_products > columns_mobile_int
      assign show_mobile_slider = true
    endif
    assign show_desktop_slider = false
    if section.settings.enable_desktop_slider and total_products > columns_desktop_int
      assign show_desktop_slider = true
    endif
  -%}

  <div class="color-{{ section.settings.color_scheme }} isolate gradient">
    <div class="section-{{ section.id }}-padding">
      <div class="page-width">
        {%- if section.settings.title != blank -%}
          <div class="title-wrapper-with-link title-wrapper--no-top-margin{% if show_mobile_slider %} title-wrapper--self-padded-tablet-down{% endif %}">
            <h2 class="complete-stack__title title inline-richtext {{ section.settings.heading_size }}">
              {{ section.settings.title }}
            </h2>
            {%- if section.settings.subtitle != blank -%}
              <span class="caption-with-letter-spacing">{{ section.settings.subtitle }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if total_products > 0 -%}
          <slider-component class="slider-mobile-gutter{% if show_mobile_slider == false %} page-width-desktop{% endif %}{% if show_desktop_slider %} slider-component-desktop{% endif %}">
            <ul
              id="Slider-{{ section.id }}"
              data-id="{{ section.id }}"
              class="grid product-grid contains-card contains-card--product{% if settings.card_style == 'standard' %} contains-card--standard{% endif %} grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down{% if show_mobile_slider or show_desktop_slider %} slider{% if show_desktop_slider %} slider--desktop{% endif %}{% if show_mobile_slider %} slider--tablet grid--peek{% endif %}{% endif %}"
              role="list"
              aria-label="{{ 'general.slider.name' | t }}"
            >
              {%- assign shown = 0 -%}
              {%- assign skip_card_product_styles = false -%}
              {%- assign lazy_load = false -%}

              {%- comment %}Step 1: render block products (other brands){% endcomment -%}
              {%- for block in section.blocks -%}
                {%- if shown >= products_to_show -%}{%- break -%}{%- endif -%}
                {%- assign bp = all_products[block.settings.product] -%}
                {%- assign bl = block.settings.product_line -%}
                {%- if bp != blank and bl != current_product_line and bp.handle != current_handle -%}
                  {%- assign shown = shown | plus: 1 -%}
                  {%- if lazy_load == false and forloop.index > columns_desktop_int -%}
                    {%- assign lazy_load = true -%}
                  {%- endif -%}
                  <li id="Slide-{{ section.id }}-{{ shown }}" class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}">
                    {% render 'card-product',
                      card_product: bp,
                      media_aspect_ratio: section.settings.image_ratio,
                      image_shape: section.settings.image_shape,
                      lazy_load: lazy_load,
                      show_secondary_image: section.settings.show_secondary_image,
                      show_vendor: section.settings.show_vendor,
                      show_rating: section.settings.show_rating,
                      skip_styles: skip_card_product_styles,
                      section_id: section.id,
                      quick_add: section.settings.quick_add
                    %}
                    {%- assign skip_card_product_styles = true -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}

              {%- comment %}Step 2: supplement from brand collections{% endcomment -%}
              {%- for coll_handle in other_brands -%}
                {%- if shown >= products_to_show -%}{%- break -%}{%- endif -%}
                {%- assign col = collections[coll_handle] -%}
                {%- for coll_product in col.products -%}
                  {%- if shown >= products_to_show -%}{%- break -%}{%- endif -%}
                  {%- unless coll_product.handle == current_handle -%}
                    {%- assign is_dup = false -%}
                    {%- for block in section.blocks -%}
                      {%- assign bp = all_products[block.settings.product] -%}
                      {%- if bp != blank and bp.handle == coll_product.handle -%}
                        {%- assign is_dup = true -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- unless is_dup -%}
                      {%- assign shown = shown | plus: 1 -%}
                      {%- if lazy_load == false and shown > columns_desktop_int -%}
                        {%- assign lazy_load = true -%}
                      {%- endif -%}
                      <li id="Slide-{{ section.id }}-{{ shown }}" class="grid__item{% if show_mobile_slider or show_desktop_slider %} slider__slide{% endif %}">
                        {% render 'card-product',
                          card_product: coll_product,
                          media_aspect_ratio: section.settings.image_ratio,
                          image_shape: section.settings.image_shape,
                          lazy_load: lazy_load,
                          show_secondary_image: section.settings.show_secondary_image,
                          show_vendor: section.settings.show_vendor,
                          show_rating: section.settings.show_rating,
                          skip_styles: skip_card_product_styles,
                          section_id: section.id,
                          quick_add: section.settings.quick_add
                        %}
                        {%- assign skip_card_product_styles = true -%}
                      </li>
                    {%- endunless -%}
                  {%- endunless -%}
                {%- endfor -%}
              {%- endfor -%}
            </ul>

            {%- if show_mobile_slider or show_desktop_slider -%}
              <div class="slider-buttons">
                <button
                  type="button"
                  class="slider-button slider-button--prev"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                  aria-controls="Slider-{{ section.id }}"
                >
                  <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                </button>
                <div class="slider-counter caption">
                  <span class="slider-counter--current">1</span>
                  <span aria-hidden="true"> / </span>
                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                  <span class="slider-counter--total">{{ total_products }}</span>
                </div>
                <button
                  type="button"
                  class="slider-button slider-button--next"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                  aria-controls="Slider-{{ section.id }}"
                >
                  <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
                </button>
              </div>
            {%- endif -%}
          </slider-component>
        {%- else -%}
          <div class="complete-stack__empty">
            <p>{{ section.settings.empty_message }}</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Complete Stack",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Título",
      "default": "Completa tu stack"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h1", "label": "H1" },
        { "value": "h0", "label": "H0" },
        { "value": "hxl", "label": "HXL" },
        { "value": "hxxl", "label": "HXXL" }
      ],
      "default": "h2",
      "label": "Tamaño del título"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Descubre productos complementarios de otras líneas"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Productos a mostrar"
    },
    {
      "type": "header",
      "content": "Configuración de cuadrícula"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adaptable" },
        { "value": "portrait", "label": "Retrato" },
        { "value": "square", "label": "Cuadrado" }
      ],
      "default": "square",
      "label": "Proporción de imagen"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        { "value": "default", "label": "Predeterminado" },
        { "value": "arch", "label": "Arco" },
        { "value": "blob", "label": "Mancha" },
        { "value": "chevronleft", "label": "Chevron izquierdo" },
        { "value": "chevronright", "label": "Chevron derecho" },
        { "value": "diamond", "label": "Diamante" },
        { "value": "parallelogram", "label": "Paralelogramo" },
        { "value": "round", "label": "Redondo" }
      ],
      "default": "default",
      "label": "Forma de imagen",
      "info": "Se usa solo para la primera imagen de la tarjeta."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Columnas en escritorio"
    },
    {
      "type": "checkbox",
      "id": "enable_desktop_slider",
      "default": false,
      "label": "Habilitar slider en escritorio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Mostrar segunda imagen al hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Mostrar vendedor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Mostrar calificación"
    },
    {
      "type": "select",
      "id": "quick_add",
      "options": [
        { "value": "none", "label": "Ninguno" },
        { "value": "standard", "label": "Estándar" },
        { "value": "bulk", "label": "Compra al por mayor" }
      ],
      "default": "none",
      "label": "Botón de compra rápida"
    },
    {
      "type": "header",
      "content": "Configuración móvil"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1 columna" },
        { "value": "2", "label": "2 columnas" }
      ],
      "default": "1",
      "label": "Columnas en móvil"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": true,
      "label": "Habilitar deslizamiento en móvil"
    },
    {
      "type": "header",
      "content": "Estado vacío"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Mensaje cuando no hay productos",
      "default": "No hay productos complementarios disponibles en este momento."
    },
    {
      "type": "header",
      "content": "Esquema de color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Esquema de color"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado superior",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Espaciado inferior",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Producto",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Seleccionar producto"
        },
        {
          "type": "select",
          "id": "product_line",
          "label": "Línea del producto",
          "options": [
            { "value": "Healthy Sports", "label": "Healthy Sports" },
            { "value": "Healthy America", "label": "Healthy America" },
            { "value": "Nutrivita", "label": "Nutrivita" }
          ],
          "default": "Healthy America"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Complete Stack",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
